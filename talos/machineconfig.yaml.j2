---
# Base machine config template.
# Rendered: minijinja-cli machineconfig.yaml.j2 talos-secrets.sops.yaml (decrypted)
# Secrets accessible as `data.*`, values.yaml keys accessible at top level.
version: v1alpha1
machine:
  token: {{ data.machine.token | safe }}
  ca:
    crt: {{ data.machine.ca.crt | safe }}
    key: {{ data.machine.ca.key | safe }}
  features:
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: false
      resolveMemberNames: true
    kubePrism:
      enabled: true
      port: {{ cluster.kubePrismPort }}
    kubernetesTalosAPIAccess:
      enabled: true
      allowedRoles:
        - os:admin
      allowedKubernetesNamespaces:
        - system-upgrade
    rbac: true
  files:
    - op: create
      path: /etc/cri/conf.d/20-customization.part
      content: |
        [plugins."io.containerd.cri.v1.images"]
          discard_unpacked_layers = false
        [plugins."io.containerd.cri.v1.runtime"]
          device_ownership_from_security_context = true
    - op: overwrite
      path: /etc/nfsmount.conf
      permissions: 0o644
      content: |
        [ NFSMount_Global_Options ]
        nfsvers=4
        soft=True
        timeo=50
        retrans=2
  kernel:
    modules:
      - name: nbd
  install:
    # installDisk is overridden per-node via the node patch
    disk: /dev/sda
    image: factory.talos.dev/installer/{{ schematicId }}:{{ talosVersion }}
    wipe: false
    grubUseUKICmdline: true
  kubelet:
    image: ghcr.io/siderolabs/kubelet:{{ kubernetesVersion }}
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    extraConfig:
      serializeImagePulls: false
      shutdownGracePeriod: 2m
      shutdownGracePeriodCriticalPods: 1m
    nodeIP:
      validSubnets:
        - {{ data.network.nodeSubnet }}
  time:
    servers:
{% for server in ntp.servers %}
      - {{ server }}
{% endfor %}
  sysctls:
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
    net.core.default_qdisc: fq
    net.core.rmem_max: "67108864"
    net.core.wmem_max: "67108864"
    net.ipv4.tcp_congestion_control: bbr
    net.ipv4.tcp_fastopen: "3"
    net.ipv4.tcp_mtu_probing: "1"
    net.ipv4.tcp_rmem: 4096 87380 33554432
    net.ipv4.tcp_wmem: 4096 65536 33554432
    net.ipv4.tcp_slow_start_after_idle: "0"
    sunrpc.tcp_max_slot_table_entries: "128"
    sunrpc.tcp_slot_table_entries: "128"
cluster:
  id: {{ data.cluster.id | safe }}
  secret: {{ data.cluster.secret | safe }}
  token: {{ data.cluster.token | safe }}
  secretboxEncryptionSecret: {{ data.secrets.secretboxencryptionsecret | safe }}
  ca:
    crt: {{ data.cluster.ca.crt | safe }}
    key: {{ data.cluster.ca.key | safe }}
  aggregatorCA:
    crt: {{ data.cluster.aggregatorCA.crt | safe }}
    key: {{ data.cluster.aggregatorCA.key | safe }}
  serviceAccount:
    key: {{ data.serviceAccount.key | safe }}
  clusterName: {{ cluster.name }}
  controlPlane:
    endpoint: https://{{ data.network.vip }}:6443
  network:
    dnsDomain: {{ cluster.dnsDomain }}
    podSubnets:
      - {{ cluster.podSubnet }}
    serviceSubnets:
      - {{ cluster.serviceSubnet }}
    cni:
      name: none
  allowSchedulingOnControlPlanes: false
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: true
      service:
        disabled: false
  etcd:
    ca:
      crt: {{ data.cluster.etcd.ca.crt | safe }}
      key: {{ data.cluster.etcd.ca.key | safe }}
    advertisedSubnets:
      - {{ data.network.nodeSubnet }}
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
  coreDNS:
    disabled: true
  proxy:
    disabled: true
  apiServer:
    image: registry.k8s.io/kube-apiserver:{{ kubernetesVersion }}
    extraArgs:
      enable-aggregator-routing: "true"
      feature-gates: MutatingAdmissionPolicy=true
      runtime-config: admissionregistration.k8s.io/v1beta1=true
      service-cluster-ip-range: {{ cluster.serviceSubnet }}
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
    disablePodSecurityPolicy: true
  controllerManager:
    image: registry.k8s.io/kube-controller-manager:{{ kubernetesVersion }}
    extraArgs:
      bind-address: 0.0.0.0
      cluster-cidr: {{ cluster.podSubnet }}
      service-cluster-ip-range: {{ cluster.serviceSubnet }}
      node-cidr-mask-size-ipv4: "24"
  scheduler:
    image: registry.k8s.io/kube-scheduler:{{ kubernetesVersion }}
    extraArgs:
      bind-address: 0.0.0.0
    
