---
# k8s-01 — controlplane + worker, Intel iGPU for Jellyfin transcoding.
apiVersion: v1alpha1
kind: HostnameConfig
hostname: k8s-01
---
version: v1alpha1
machine:
  type: controlplane
  install:
    disk: {{ nodes['k8s-01'].installDisk }}
  network:
    interfaces:
      - interface: ens18
        addresses:
          - {{ data.nodes['k8s-01'].ip }}/{{ data.network.nodePrefix }}
        routes:
          - network: 0.0.0.0/0
            gateway: {{ data.network.gateway }}
            metric: 1024
        vip:
          ip: {{ data.network.vip }}
  nodeLabels:
    node-role: worker
    intel.feature.node.kubernetes.io/gpu: "true"
  # Longhorn requires /var/mnt/longhorn to be bind-mounted into kubelet's view.
  # The disk ({{ nodes['k8s-01'].dataDisk }}) is managed entirely by Longhorn.
  kubelet:
    extraMounts:
      - destination: /var/mnt/longhorn
        type: bind
        source: /var/mnt/longhorn
        options:
          - bind
          - rshared
          - rw
cluster:
  allowSchedulingOnControlPlanes: true
